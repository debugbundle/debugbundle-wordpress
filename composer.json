{
  "name": "debugbundle/wordpress-plugin",
  "description": "DebugBundle WordPress plugin",
  "homepage": "https://debugbundle.com/docs/integrations/wordpress",
  "license": "GPL-2.0-or-later",
  "type": "wordpress-plugin",
  "support": {
    "issues": "https://github.com/debugbundle/debugbundle-wordpress/issues",
    "source": "https://github.com/debugbundle/debugbundle-wordpress"
  },
  "require": {
    "php": ">=8.2",
    "debugbundle/sdk-php": "^1.1.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "phpstan/phpstan": "^2.1"
  },
  "autoload": {
    "psr-4": {
      "DebugBundleWp\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "DebugBundleWp\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml.dist",
    "typecheck": "phpstan analyse --memory-limit=512M"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
